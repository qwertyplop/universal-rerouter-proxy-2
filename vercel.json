{
  "version": 2,
  "functions": {
    "api/proxy.py": { "entrypoint": "app" }
  },
  "rewrites": [
    { "source": "/janitorai/:path*", "destination": "/api/proxy" },
    { "source": "/sillytavern/:path*", "destination": "/api/proxy" },
    { "source": "/health/:path*", "destination": "/api/proxy" },
    { "source": "/((?!api/|janitorai/|sillytavern/|health/|public/).*)", "destination": "/public/index.html" }
  ]
}
