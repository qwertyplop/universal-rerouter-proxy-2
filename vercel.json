{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/janitorai(.*)", "dest": "/api/index.py" },
    { "src": "/sillytavern(.*)", "dest": "/api/index.py" },
    { "src": "/health(.*)", "dest": "/api/index.py" }
  ]
}
