{
  "version": 2,
  "builds": [
    { "src": "api/proxy.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/(janitorai|sillytavern|health|api/proxy)(/.*)?", "dest": "api/proxy.py" },
    { "src": "/(.+\\.\\w+)$", "dest": "/$1" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
