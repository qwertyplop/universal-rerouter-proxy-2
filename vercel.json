{
  "version": 2,
  "builds": [
    { "src": "api/proxy.py", "use": "@vercel/python" },
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "public/**/*", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/(janitorai|sillytavern|health|api/proxy)(/.*)?", "dest": "api/proxy.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
