{
  "version": 2,
  "framework": null,
  "builds": [
    { "src": "api/index.py", "use": "@vercel/python" }
  ],
  "rewrites": [
    { "source": "/janitorai/:path*", "destination": "/api/index" },
    { "source": "/sillytavern/:path*", "destination": "/api/index" },
    { "source": "/health/:path*", "destination": "/api/index" },
    { "source": "/((?!api/).*)", "destination": "/public/index.html" }
  ]
}
